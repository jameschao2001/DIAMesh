# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
build/
dist/
*.egg-info/
.eggs/
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# DIAMesh outputs
outputs/
*.png
*.jpg
*.glb
# Track sample / reference fbx in tests/fixtures, ignore everything else:
*.fbx
!tests/fixtures/*.fbx

# Vendor: Blender portable is too large for git (~450 MB). Operator
# drops it into vendor/blender/ per BLENDER_SETUP.md. Keep .gitkeep so
# the directory exists in fresh clones.
vendor/blender/*
!vendor/blender/.gitkeep
